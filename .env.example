# ============================================
# SPORTS CARD TAGGER - Environment Template
# ============================================
# Copy this file to .env and fill in your values
# Used locally; on Render, set via Environment Variables

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection details
# On Render: These are auto-populated from the PostgreSQL service
# Locally: Use your development PostgreSQL instance

DB_HOST=localhost
DB_PORT=5432
DB_NAME=sports_card_tagger
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Full PostgreSQL connection string (alternative to individual fields)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# COLLECTOR INVESTOR API AUTHENTICATION
# ============================================
# Required to fetch listings from Collector Investor Auctions API
# Obtain these credentials from Collector Investor

COLLECTOR_INVESTOR_USERNAME=your_collector_investor_username
COLLECTOR_INVESTOR_BASE64_TOKEN=your_collector_investor_base64_encoded_token

# ============================================
# AZURE OPENAI CONFIGURATION
# ============================================
# Used for AI tag generation (3-pass pipeline)
# Create an Azure OpenAI resource in Azure Portal

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4-vision
AZURE_OPENAI_API_KEY=your_azure_openai_api_key

# ============================================
# TAG GENERATION SETTINGS
# ============================================
# Minimum and maximum number of tags per product
TAG_COUNT_MIN=40
TAG_COUNT_MAX=50

# Temperature for tag generation (0.0 = deterministic, 1.0 = creative)
TAG_TEMPERATURE=0.3

# Max tokens for tag generation response
TAG_MAX_TOKENS=800

# ============================================
# API SERVER SETTINGS
# ============================================
# Only used locally; on Render these are set by Render
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
